<%= turbo_frame_tag dom_id(student) do %>
  <div class="student-card">
    <p>Name: <%= student.name %></p>

    <div class="actions">
      <%= link_to "View", student_path(student, search: params[:search], course: params[:course]), data: { turbo_frame: "_top" } %>

      <%= link_to "Edit", edit_student_path(student, search: params[:search], course: params[:course]), data: { turbo_frame: dom_id(student)} %>

      <%= button_to "Delete",
            student_path(student, search: params[:search], course: params[:course]),
            method: :delete,
            data: { turbo_confirm: "Are you sure?" } %>
    </div>
  </div>
<% end %>